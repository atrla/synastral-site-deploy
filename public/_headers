# Netlify / Cloudflare Pages header rules (WP6).
#
# This file format (`_headers`, path-prefix + indented "Header: value"
# lines) is Netlify- and Cloudflare Pages-specific. Other static hosts use
# different mechanisms — e.g. Vercel wants a `headers` array in
# `vercel.json`, GitHub Pages has no header config at all, S3/CloudFront
# needs cache-control set on the S3 objects or in a CloudFront response
# headers policy, and most VPS/nginx setups configure this in the nginx
# server block. If deploying anywhere other than Netlify/Cloudflare Pages,
# port these same rules to that host's config format.
#
# Vite content-hashes every file under /assets/ (images, fonts, CSS, JS —
# see src/assets/* imports and vite.config.js's default build output), so
# those URLs are safe to cache forever and immutably: a content change
# always produces a new filename, never the same URL with different bytes.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML entry points should always be revalidated so deploys show up
# immediately — index.html references the hashed asset URLs above, so it
# must never be served stale from a shared/browser cache.
/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

/404.html
  Cache-Control: no-cache

# Crawl-surface files (WP10) change over time (sitemap lastmod, robots
# rules, llms.txt) and live at fixed, well-known URLs — keep them
# revalidated rather than aggressively cached so crawlers see updates
# promptly.
/robots.txt
  Cache-Control: no-cache

/sitemap.xml
  Cache-Control: no-cache

/llms.txt
  Cache-Control: no-cache

# Security headers (WP-2.2, pairs with WP-2.3 analytics).
#
# 'unsafe-inline' in style-src is required because components set inline
# style attributes (style="..."); it does not affect script execution.
# JSON-LD <script type="application/ld+json"> blocks are inert data, not
# executable script, so they are never blocked by script-src regardless of
# its value.
# If an inline bootstrap <script> (no src attribute) is ever added to
# index.html, script-src's default-src/self-only posture will block it —
# add that script's sha256-<hash> to script-src rather than loosening it
# to 'unsafe-inline'.
# Microsoft Clarity's beacon/collection subdomains are not officially
# published or guaranteed stable — verify the *.clarity.ms wildcard still
# covers Clarity's current regional endpoints against Microsoft's docs at
# deploy time (https://learn.microsoft.com/en-us/clarity/).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.googletagmanager.com https://www.clarity.ms https://*.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://www.googletagmanager.com https://*.google-analytics.com; font-src 'self'; connect-src 'self' https://api.synastral.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://*.clarity.ms; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
